{
  "name": "@dcacheson/spotter",
  "version": "0.2.0",
  "description": "Deterministic-first CLI for turning frontend UX scenarios into Playwright visual regression coverage.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dacheson/spotter.git"
  },
  "homepage": "https://github.com/dacheson/spotter#readme",
  "bugs": {
    "url": "https://github.com/dacheson/spotter/issues"
  },
  "bin": {
    "spotter": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts",
    "pack:check": "npm pack --dry-run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run test",
    "release:check": "npm run typecheck && npm run test && npm run build && npm run pack:check",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "visual-regression",
    "cli",
    "nextjs",
    "typescript"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "commander": "^14.0.3",
    "jiti": "^2.6.1",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.2.4",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
